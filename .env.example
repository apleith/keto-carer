# ── AI Provider ──────────────────────────────────────────────────────────────
# Set to "claude" to use Anthropic API, or "ollama" for local Ollama
AI_PROVIDER=ollama

# Required if AI_PROVIDER=claude
ANTHROPIC_API_KEY=

# Ollama settings (used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Nutrition ────────────────────────────────────────────────────────────────
# Get a free key at https://fdc.nal.usda.gov/api-guide.html
# DEMO_KEY works but is rate-limited (1000 req/hour, 30 req/min)
USDA_API_KEY=DEMO_KEY

# ── Notifications (ntfy.sh) ──────────────────────────────────────────────────
# Leave as-is to use the free ntfy.sh cloud service
NTFY_BASE_URL=https://ntfy.sh
# Each user's topic is set in-app via Settings

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=true
RESEARCH_INTERVAL_DAYS=7
